{
    "redirects": [
        {
            "source": "/insights/wrong-question-ai-cxo",
            "destination": "/insights/wrong-question-ai-leader",
            "permanent": true
        },
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "www.mosesnyanzi.co.za"
                }
            ],
            "destination": "https://mosesnyanzi.co.za/:path*",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/insights",
            "destination": "/"
        },
        {
            "source": "/insights/",
            "destination": "/"
        },
        {
            "source": "/insights/:path*",
            "destination": "/"
        }
    ],
    "headers": [
        {
            "source": "/assets/:path*",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://va.vercel-scripts.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https://www.google-analytics.com; connect-src 'self' https://vitals.vercel-insights.com https://www.google-analytics.com;"
                }
            ]
        }
    ]
}
